#!/usr/bin/env python3
import base64
import configparser
import json
import os
import re
import secrets
import stat
import sys
from pathlib import Path

import serial
from cryptography.exceptions import InvalidSignature
from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PublicKey

CONFIG_PATH = Path('/etc/ed25519-token-auth/host.conf')
DEFAULT_DEVICE = '/dev/ed25519-token'
DEFAULT_KEY_DIR = '/etc/ed25519-token-auth/keys'
DEFAULT_SERVICE = 'sddm-token'
DEFAULT_PREFIX = 'sddm-ed25519-token-v1'
DEFAULT_BAUDRATE = 115200
DEFAULT_TIMEOUT = 3
USER_RE = re.compile(r'^[a-z_][a-z0-9_-]{0,31}$')


def fail(message: str, code: int = 1) -> None:
    print(f'pam-ed25519-token: {message}', file=sys.stderr)
    raise SystemExit(code)


def load_config():
    cfg = configparser.ConfigParser()
    cfg.read(CONFIG_PATH)
    device = cfg.get('token', 'device', fallback=DEFAULT_DEVICE)
    timeout = cfg.getfloat('token', 'timeout_seconds', fallback=DEFAULT_TIMEOUT)
    key_dir = cfg.get('security', 'key_dir', fallback=DEFAULT_KEY_DIR)
    service = cfg.get('security', 'allowed_service', fallback=DEFAULT_SERVICE)
    prefix = cfg.get('security', 'protocol_prefix', fallback=DEFAULT_PREFIX).encode('utf-8')
    baudrate = cfg.getint('serial', 'baudrate', fallback=DEFAULT_BAUDRATE)
    return device, timeout, key_dir, service, prefix, baudrate


def make_message(prefix: bytes, user: str, service: str, challenge: bytes) -> bytes:
    return prefix + b'\x00' + user.encode('utf-8') + b'\x00' + service.encode('utf-8') + b'\x00' + challenge


def read_public_key(path: Path) -> Ed25519PublicKey:
    st = path.stat()
    if st.st_uid != 0:
        fail(f'public key is not owned by root: {path}')
    if st.st_mode & (stat.S_IWGRP | stat.S_IWOTH):
        fail(f'public key is group/world writable: {path}')
    raw = path.read_bytes()
    if len(raw) != 32:
        fail(f'public key must be 32 raw bytes: {path}')
    return Ed25519PublicKey.from_public_bytes(raw)


def main() -> int:
    pam_service = os.environ.get('PAM_SERVICE', '')
    pam_type = os.environ.get('PAM_TYPE', '')
    user = os.environ.get('PAM_USER', '')

    device, timeout, key_dir, allowed_service, prefix, baudrate = load_config()

    if pam_service != allowed_service:
        fail(f'refusing PAM service {pam_service!r}')
    if pam_type != 'auth':
        fail(f'refusing PAM type {pam_type!r}')
    if not USER_RE.match(user):
        fail('invalid or missing PAM_USER')

    public_key_path = Path(key_dir) / f'{user}.pub'
    if not public_key_path.exists():
        fail(f'public key not found for user {user!r}')

    public_key = read_public_key(public_key_path)
    challenge = secrets.token_bytes(32)

    request = {
        'v': 1,
        'op': 'sign',
        'user': user,
        'service': allowed_service,
        'challenge': base64.b64encode(challenge).decode('ascii'),
    }

    try:
        with serial.Serial(device, baudrate=baudrate, timeout=timeout, exclusive=True) as ser:
            ser.write((json.dumps(request, separators=(',', ':')) + '\n').encode('utf-8'))
            ser.flush()
            line = ser.readline()
    except Exception as exc:
        fail(f'failed to communicate with token: {exc}')

    if not line:
        fail('token timeout')

    try:
        response = json.loads(line.decode('utf-8'))
    except Exception as exc:
        fail(f'invalid JSON response from token: {exc}')

    if not response.get('ok'):
        fail(f'token refused request: {response.get("error", "unknown_error")}')

    if response.get('alg') != 'Ed25519':
        fail('unexpected signature algorithm')

    try:
        signature = base64.b64decode(response['signature'], validate=True)
    except Exception:
        fail('invalid signature encoding')

    message = make_message(prefix, user, allowed_service, challenge)

    try:
        public_key.verify(signature, message)
    except InvalidSignature:
        fail('invalid token signature')

    return 0


if __name__ == '__main__':
    raise SystemExit(main())
